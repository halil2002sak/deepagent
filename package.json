{
  "name": "deepagent",
  "version": "1.0.0",
  "description": "DeepSeek-powered autonomous AI agent for Linux with kernel-level system access",
  "type": "module",
  "bin": {
    "deepagent": "./bin/deepagent.js"
  },
  "scripts": {
    "start": "bun run src/main.ts",
    "build": "bun build src/main.ts --outdir dist --target node",
    "dev": "bun run --watch src/main.ts"
  },
  "dependencies": {
    "openai": "^4.77.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.1",
    "inquirer": "^12.3.0",
    "marked": "^15.0.4",
    "marked-terminal": "^7.2.1",
    "conf": "^13.0.1",
    "cli-highlight": "^2.1.11"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/inquirer": "^9.0.7"
  }
}
